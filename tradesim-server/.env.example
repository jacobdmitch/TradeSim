# ---- Database ----
# On Render this is injected automatically from the linked Postgres instance.
# Locally, leave blank to use a local SQLite file (tradesim.db).
DATABASE_URL=

# ---- Coinbase Advanced Trade API (CDP key) ----
# Create at https://portal.cdp.coinbase.com/ -> API Keys.
# SCOPE THE KEY TO "TRADE" ONLY. Do NOT grant transfer/withdraw.
# COINBASE_API_KEY is the key *name*, e.g.
#   organizations/xxxx/apiKeys/yyyy
# COINBASE_API_SECRET is the private key PEM (Ed25519 or EC). Keep the literal
# newlines, or replace them with \n — both are handled.
COINBASE_API_KEY=
COINBASE_API_SECRET=

# ---- Trading controls (DB settings override these after first run) ----
# Master switch. false = analyze and log only, never place orders.
TRADING_ENABLED=false
# Paper mode. true = simulate fills, do not call Coinbase order endpoints.
# Start here. Flip to false only when you're ready to risk real funds.
DRY_RUN=true
# Your real starting stake, in USD. Seeds the first DIMO position.
STARTING_BALANCE=23.17
# Halt all new entries/rotations if total account value falls to/below this.
BALANCE_FLOOR_USD=0.0

# ---- Dashboard ----
# Optional shared password for the dashboard control actions.
DASHBOARD_TOKEN=
